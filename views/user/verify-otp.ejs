<%- include("../partials/header") %>
<style>
  .otp-timer {
    display: inline-block;
    margin-left: 10px;
    font-size: 14px;
  }
</style>
<div class="container col-4 login_wrap widget-taber-content p-30 background-white border-radius-5 mt-30">
  <div class="padding_eight_all bg-white">
    <div class="heading_s1">
      <h3 class="mb-30">Email Verification Page</h3>
    </div>
    <form action="/verify-otp" method="post" onsubmit="return validateOTPForm()">
      <div class="form-group">
        <label for="otp">Enter OTP:</label>
        <input type="text" id="otp" name="otp" class="form-control" required />
      </div>
      <button type="submit" class="btn btn-primary text-center">
        Verify Email
      </button>
      <br><br>
      <div class="form-group">
        <span id="otpTimer" class="otp-timer"></span>
        <button type="button" onclick="resendOTP()">Resend OTP</button>
      </div>
      <% if (locals.message && message.length > 0) { %>
        <div class="alert alert-danger"><%= message %></div>
      <% } %>
    </form>
    <div class="text-muted text-center pt-25">
      Already verified? <a href="/login">Login now</a>
    </div>
  </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
<script>
  // Function to start the OTP timer
  function startOTPTimer(durationInSeconds) {
    let timer = durationInSeconds;
    const timerElement = document.getElementById('otpTimer');
    const countdown = setInterval(function () {
      const minutes = Math.floor(timer / 60);
      const seconds = timer % 60;

      timerElement.textContent = `${minutes}:${seconds < 10 ? '0' : ''}${seconds}`;

      if (--timer < 0) {
        clearInterval(countdown);
        timerElement.textContent = 'OTP Expired';
      }
    }, 1000);
  }

  function resendOTP() {
    // Trigger the OTP resend AJAX call
    $.ajax({
      type: 'POST',
      url: '/resend-otp',
      success: function (response) {
        if (response.success) {
          // If OTP resend is successful, start the timer
          startOTPTimer(60);
        } else {
          // Handle the case where OTP resend fails (e.g., display an error message)
          alert('Failed to resend OTP. Please try again.');
        }
      },
      error: function () {
        // Handle the case where there is an error in the AJAX request
        alert('Error occurred while resending OTP. Please try again.');
      }
    });
  }
  // Initialize the OTP timer with a default duration (you may adjust this as needed)
  startOTPTimer(60);
  function validateOTPForm() {
    // Implement your OTP validation logic here
    // Return true if the form is valid, otherwise return false
    return true; // Change this based on your validation logic
  }
</script>
<%- include("../partials/footer") %>